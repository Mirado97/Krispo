# ============================================================
# PolyBot — copy to .env and fill in real values
# ============================================================

# === SIMULATION MODE (set false for live trading) ===
DRY_RUN=true

# --- Wallet (required for live) ---
PRIVATE_KEY=0x...
WALLET_ADDRESS=0x...
# SIGNATURE_TYPE: 0=EOA       (maker=WALLET_ADDRESS, pUSD must be on WALLET_ADDRESS)
#                 3=POLY_1271  (maker=deposit wallet — Polymarket V2 standard flow)
#
# POLY_1271 setup (one time):
#   1. npm run setup-deposit-wallet   → get DEPOSIT_WALLET address
#   2. Withdraw from Polymarket UI → USDC on WALLET_ADDRESS
#   3. npm run wrap-usdc <amount>     → wrap USDC→pUSD into deposit wallet
#   4. npm run setup-approvals        → approve CTF Exchange
#   5. SIGNATURE_TYPE=3, PROXY_ADDRESS=<deposit_wallet>
SIGNATURE_TYPE=3
PROXY_ADDRESS=0x...  # deposit wallet address (from setup-deposit-wallet)

# --- Polymarket CLOB API (required for live) ---
# Generate with: npm run generate-keys
POLY_API_KEY=...
POLY_API_SECRET=...
POLY_API_PASSPHRASE=...

# --- Strategy: btc-5min | btc-15min ---
MARKET_STRATEGY=btc-15min
EVENT_SLUG=

# --- Trading parameters ---
ORDER_SIZE=10
MIN_SPREAD_BPS=150
MAX_SPREAD_BPS=800
INVENTORY_SKEW_FACTOR=0.001
REQUOTE_THRESHOLD_BPS=30

# --- Risk limits ---
MAX_LOSS=500
MAX_POSITION=1000
MAX_NOTIONAL=5000
DAILY_SPEND_CAP=200
INVENTORY_HOLD_MAX_CYCLES=60

# --- Volatility ---
VOL_EWMA_ALPHA=0.06

# --- Ladder orders ---
MODE_LADDER=true
LADDER_LEVELS=3
LADDER_STEP=0.02
LADDER_SIZES=50,30,20
LADDER_ENTRY_DISCOUNT=0.05
LADDER_MAX_COMBINED=0.97

# --- CTF Split mode ---
MODE_CTF_SPLIT=true
CTF_SPLIT_TRIGGER_MIN=0.45
CTF_SPLIT_TRIGGER_MAX=0.55
CTF_SPLIT_SIZE=10
CTF_EXIT_K=0.80
CTF_VOL_MIN=0.15
CIRCUIT_BREAKER_SEC=30

# --- Taker Sweep ---
MODE_TAKER_SWEEP=true
TAKER_THRESHOLD=0.90
TAKER_SIZE=20
TAKER_EDGE_MIN=0.02

# --- Infrastructure ---
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
LOG_LEVEL=info
